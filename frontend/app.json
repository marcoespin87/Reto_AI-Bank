{
  "expo": {
    "name": "AI-Bank mAiles",
    "slug": "ai-bank-mailes",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#071325"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aibank.mailes"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#071325"
      },
      "package": "com.aibank.mailes"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
